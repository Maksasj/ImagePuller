{
  "manifest_version": 3,
  "name": "Image Puller",
  "version": "1.0",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["http://localhost:41595/"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}